; dest = (src1 < imm) ? 1 : 0 (signed)
>OP_SLTI ENTAL INSN_WORD2
STRAL IMM_LOWER
JPALNG SLTI_NEG
CL IMM_UPPER

>SLTI_COMPARE ENTB INSN_SRC1_OFFSET
ENTALB REG_0_HI
SLCP IMM_UPPER
SLCL CONST_SIGN_BIT_31
JPALNZ SLTI_DIFF_SIGNS
ENTAUB REG_0_HI
ENTALB REG_0_LO
SUBA IMM_LOWER
JPAUNG STORE_TRUE
JP STORE_FALSE

>SLTI_DIFF_SIGNS ENTAL IMM_UPPER
SLCL CONST_SIGN_BIT_31
JPALNZ STORE_FALSE
JP STORE_TRUE

>SLTI_NEG ENTAL CONST_MASK_14BIT
STRAL IMM_UPPER
JP SLTI_COMPARE

