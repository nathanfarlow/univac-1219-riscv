>OP_SLTIU ENTAL INSN_WORD2
STRAL IMM_LOWER
JPALNG SLTIU_NEG
CL IMM_UPPER

>SLTIU_COMPARE ENTB INSN_SRC1_OFFSET
ENTALB REG_0_HI
SLSET CONST_UNSIGNED_CMP_BIT
STRAL TMP_LO
ENTALB REG_0_LO
ENTAU TMP_LO
SUBA IMM_LOWER
LSHA 1
JPAUNG STORE_FALSE
JP STORE_TRUE

>SLTIU_NEG ENTAL CONST_MASK_14BIT
STRAL IMM_UPPER
JP SLTIU_COMPARE
